# DAVE Environment Configuration Example
# Copy this file to .env in the application root and update with your actual values
# IMPORTANT: After creating .env file, set permissions: chmod 600 .env

# ====================================================================================
# CORE APPLICATION SETTINGS
# ====================================================================================
DAVE_BASE_URL=https://yourdomain.com
DAVE_API_URL=https://yourdomain.com/api
DAVE_ADMIN_USER=admin
DAVE_ADMIN_DEFAULT_PASSWORD=password
DAVE_INTEGRATION_API_KEY=XXXXXXXXX
DAVE_ASSETS_URL=https://yourdomain.com/assets
DAVE_ENVIRONMENT=production
DAVE_DEBUG=false

# ====================================================================================
# DATABASE CONFIGURATION
# ====================================================================================
DB_HOST=localhost
DB_PORT=5432
DB_NAME=dave_db
DB_USER=dave_user
DB_PASSWORD=your_secure_db_password_here

# ====================================================================================
# EMAIL CONFIGURATION
# ====================================================================================
DAVE_SMTP_HOST=smtp.yourdomain.com
DAVE_SMTP_PORT=587
DAVE_SMTP_USERNAME=noreply@yourdomain.com
DAVE_SMTP_PASSWORD=your_smtp_password
DAVE_SMTP_ENCRYPTION=tls
DAVE_FROM_EMAIL=noreply@yourdomain.com
DAVE_FROM_NAME='DAVE System'

# ====================================================================================
# SECURITY CONFIGURATION
# ====================================================================================
DAVE_SESSION_DOMAIN=yourdomain.com
DAVE_COOKIE_DOMAIN=yourdomain.com
DAVE_SESSION_LIFETIME=3600
DAVE_MAX_LOGIN_ATTEMPTS=5
DAVE_LOCKOUT_DURATION=900

# ====================================================================================
# EXTERNAL API KEYS
# ====================================================================================
OPENFDA_API_KEY=your_fda_api_key_here
NVD_API_KEY=your_nvd_api_key_here
MAXMIND_API_KEY=your_maxmind_api_key_here
MAXMIND_ACCOUNT_ID=your_maxmind_account_id_here

# ====================================================================================
# FILE UPLOAD SETTINGS
# ====================================================================================
DAVE_MAX_UPLOAD_SIZE=52428800
DAVE_UPLOAD_DIR=/var/www/html/uploads
DAVE_TEMP_DIR=/var/www/html/temp

# ====================================================================================
# LOGGING CONFIGURATION
# ====================================================================================
DAVE_LOG_LEVEL=ERROR
DAVE_LOG_FILE=/var/www/html/logs/dave.log
DAVE_LOG_MAX_SIZE=10485760
DAVE_LOG_MAX_FILES=5

# ====================================================================================
# CACHE CONFIGURATION
# ====================================================================================
DAVE_CACHE_ENABLED=true
DAVE_CACHE_DIR=/var/www/html/temp/cache
DAVE_CACHE_LIFETIME=3600

# ====================================================================================
# PERFORMANCE CONFIGURATION
# ====================================================================================
DAVE_API_RATE_LIMIT=100
DAVE_API_RATE_WINDOW=60


# ====================================================================================
# CYNERIO CONFIGURATION
# ====================================================================================
CYNERIO_CLIENT_ID=XXXXXX
CYNERIO_CLIENT_SECRET=XXXXXX

CYNERIO_ENDPOINT=https://us.app.cynerio.com
CYNERIO_AUTH_ENDPOINT=https://us-portal-login.cynerio.com


# ====================================================================================
# BLUEFLOW CONFIGURATION
# ====================================================================================

BLUEFLOW_API_URL=https://blueflow-mock-api.fly.dev/api"


# ====================================================================================
# NETDISCO CONFIGURATION
# ====================================================================================

NETDISCO_API_URL=http://x.x.x.x:5000/api/v1







