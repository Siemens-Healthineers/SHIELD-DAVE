{
    "name": "dave/cyber-security-management-system",
    "description": "Device Assessment and Vulnerability Exposure for Medical Devices",
    "type": "project",
    "license": "MIT",
    "authors": [
        {
            "name": " Development Team",
            "email": "dev@dave.com"
        }
    ],
    "require": {
        "php": ">=7.4",
        "ext-pdo": "*",
        "ext-pdo_pgsql": "*",
        "ext-curl": "*",
        "ext-json": "*",
        "ext-mbstring": "*"
    },
    "require-dev": {
        "phpunit/phpunit": "^9.5",
        "squizlabs/php_codesniffer": "^3.6",
        "phpstan/phpstan": "^1.0"
    },
    "autoload": {
        "psr-4": {
            "\\": "src/"
        },
        "classmap": [
            "config/database.php",
            "includes/auth.php"
        ],
        "files": [
            "config/config.php",
            "includes/functions.php"
        ]
    },
    "autoload-dev": {
    },
    "scripts": {
        "cs": "phpcs --standard=PSR12 includes/ api/ pages/",
        "cs-fix": "phpcbf --standard=PSR12 includes/ api/ pages/",
        "stan": "phpstan analyse includes/ api/ pages/",
        "quality": [
            "@cs",
            "@stan",
            "@test"
        ]
    },
    "config": {
        "optimize-autoloader": true,
        "sort-packages": true
    }
}
